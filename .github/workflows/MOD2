Function ConvertToARGB(ByVal vbaColor As Long, Optional ByVal Alpha As Byte = 255) As Long
    Dim R As Long, G As Long, B As Long
    R = vbaColor And &HFF
    G = (vbaColor \ &H100) And &HFF
    B = (vbaColor \ &H10000) And &HFF
    
    ' 組合為 ARGB (GDI+ 使用的格式)
    ConvertToARGB = (CLng(Alpha) * &H1000000) Or (R * &H10000) Or (G * &H100) Or B
End Function
